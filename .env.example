# NotebookLM Skill Configuration
# Copy to .env and fill in values

# Google Account (used for NotebookLM authentication)
# Run: python scripts/auth_helper.py setup
# Cookies are saved to ~/.notebooklm/ automatically

# Optional: trend-pulse integration
# TREND_PULSE_CMD=trend-pulse
# TREND_PULSE_GEO=TW
# TREND_PULSE_COUNT=10

# Optional: Threads publishing (requires threads-viral-agent)
# THREADS_TOKEN=your_threads_token
# THREADS_USER_ID=your_user_id

# Rate limiting
# NLM_MAX_NOTEBOOKS_PER_HOUR=10
# NLM_REQUEST_DELAY_SECONDS=2
